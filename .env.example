# Flask application
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=replace-with-a-random-32-byte-or-longer-secret
DATABASE_URL=sqlite:///instance/teachers.db
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_MB=8

# First administrator bootstrap
# Set these only when intentionally creating the first admin user.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-one-time-password

# Browser/session security
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
WTF_CSRF_TIME_LIMIT=3600
RATELIMIT_STORAGE_URI=memory://

# Recognition worker / hardware integration
RECOGNITION_DATABASE_URL=sqlite:///instance/teachers.db
RECOGNITION_UPLOAD_FOLDER=uploads
ARDUINO_SERIAL_PORT=COM9
ARDUINO_BAUDRATE=9600
CAMERA_INDEX=0
ACCESS_LOG_FILE=
